 	function paging(data){
 		
		
  		var URLSearch = new URLSearchParams(location.search);
  		
  		var originalURL = window.location.href;
	  	var parametersToRemove = ["page"];
	  	var modifiedURL = removeURLParameters(originalURL, parametersToRemove);
	  					
	  	
 		switch(data){
 		
