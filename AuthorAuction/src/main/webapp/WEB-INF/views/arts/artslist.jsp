 				location.href = modifiedURL + "?page="+${pi.maxPage}; break;
 			}else if( URLSearch.size == 1 && URLSearch.get('page')){
 				location.href = modifiedURL + "?page="+${pi.maxPage}; break;
 			}else{
 				location.href = modifiedURL + "&page="+${pi.maxPage}; break;
 			}
 			}
 			break;
 		
 		default:
 			
 			if(URLSearch.size == 0){
 				location.href = modifiedURL + "?page="+data; break;
 			}else if( URLSearch.size == 1 && URLSearch.get('page')){
 				location.href = modifiedURL + "?page="+data; break;
 			}else{
 				location.href = modifiedURL + "&page="+data; break;
 			}
 			break;
 			
 		
 		}
 		
 		
 		
 	}
  
  
  
